{
    "singleQuote": true,
    "trailingComma": "all",
    "tabWidth": 4,
    "printWidth": 120,
    "semi": true,
    "embeddedLanguageFormatting": "auto",
    "endOfLine": "lf",
    "arrowParens": "always",
    "bracketSpacing": true,
    "proseWrap": "preserve",
    "quoteProps": "as-needed",
    "plugins": ["prettier-plugin-tailwindcss"]
}
